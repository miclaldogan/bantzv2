# Bantz v3 — .env.example
# cp .env.example .env  →  then fill in your values

# ── Ollama (required) ─────────────────────────────────────────────────────────
# Local inference (default):
BANTZ_OLLAMA_MODEL=llama3.1:8b
BANTZ_OLLAMA_BASE_URL=http://localhost:11434
#
# Remote GPU VPS (compute offloading — #270):
#   1. Rent hourly GPU on RunPod / Vast.ai / Lambda (RTX 3090+ recommended)
#   2. Install Ollama on VPS:  curl -fsSL https://ollama.ai/install.sh | sh
#   3. Bind to localhost only:  OLLAMA_HOST=127.0.0.1 ollama serve
#   4. Pull model on VPS:       ollama pull qwen2.5:14b
#   5. Open SSH tunnel (local): ssh -N -L 11434:localhost:11434 root@<VPS_IP>
#      Or persistent service:   systemctl --user start bantz-ssh-tunnel@<VPS_IP>
#   6. Set vars below, then:    bantz --doctor   (validates connectivity + model)
#
# BANTZ_OLLAMA_MODEL=qwen2.5:14b
# BANTZ_OLLAMA_BASE_URL=http://localhost:11434   # tunnel makes remote appear local

# ── Embeddings / Vector Memory ────────────────────────────────────────────────
BANTZ_EMBEDDING_MODEL=nomic-embed-text
BANTZ_EMBEDDING_ENABLED=true
BANTZ_VECTOR_SEARCH_WEIGHT=0.5

# ── Session Distillation ──────────────────────────────────────────────────────
BANTZ_DISTILLATION_ENABLED=true
BANTZ_DISTILLATION_MIN_EXCHANGES=5

# ── Vision / Remote VLM (optional — requires vlm_server.py running) ───────────
BANTZ_VLM_ENABLED=false
BANTZ_VLM_ENDPOINT=http://localhost:8090
BANTZ_VLM_TIMEOUT=5
BANTZ_SCREENSHOT_QUALITY=70

# ── Input Control (optional — mouse/keyboard automation) ──────────────────────
BANTZ_INPUT_CONTROL_ENABLED=false
BANTZ_INPUT_CONFIRM_DESTRUCTIVE=true
BANTZ_INPUT_TYPE_INTERVAL_MS=50

# ── Gemini Flash 2.0 (optional — used as finalizer for long outputs) ──────────
BANTZ_GEMINI_ENABLED=false
BANTZ_GEMINI_API_KEY=
BANTZ_GEMINI_MODEL=gemini-2.0-flash

# ── Language / Translation ────────────────────────────────────────────────────
BANTZ_LANGUAGE=tr
BANTZ_TRANSLATION_ENABLED=true

# ── Shell Security ────────────────────────────────────────────────────────────
BANTZ_SHELL_CONFIRM_DESTRUCTIVE=true
BANTZ_SHELL_TIMEOUT_SECONDS=30

# ── Location (optional — auto-detected if empty) ─────────────────────────────
BANTZ_CITY=
BANTZ_REGION=
BANTZ_COUNTRY=TR
BANTZ_TIMEZONE=Europe/Istanbul
BANTZ_LAT=
BANTZ_LON=

# ── GPS Relay (optional — mobile GPS forwarding) ─────────────────────────────
BANTZ_GPS_RELAY_TOKEN=

# ── Neo4j Graph Memory (optional — requires docker compose up) ────────────────
BANTZ_NEO4J_ENABLED=false
BANTZ_NEO4J_URI=bolt://localhost:7687
BANTZ_NEO4J_USER=neo4j
BANTZ_NEO4J_PASSWORD=bantzpass

# ── Storage (leave blank for ~/.local/share/bantz) ────────────────────────────
BANTZ_DATA_DIR=

# ── Morning Briefing ─────────────────────────────────────────────────────────
BANTZ_MORNING_BRIEFING=true
BANTZ_MORNING_HOUR=8
BANTZ_MORNING_MINUTE=0

# ── Digests ───────────────────────────────────────────────────────────────────
BANTZ_DAILY_DIGEST_ENABLED=true
BANTZ_DAILY_DIGEST_HOUR=20
BANTZ_DAILY_DIGEST_MINUTE=0
BANTZ_WEEKLY_DIGEST_ENABLED=true
BANTZ_WEEKLY_DIGEST_DAY=sunday
BANTZ_WEEKLY_DIGEST_HOUR=20
BANTZ_WEEKLY_DIGEST_MINUTE=0

# ── Scheduler / Reminders ─────────────────────────────────────────────────────
BANTZ_REMINDER_CHECK_INTERVAL=30

# ── Job Scheduler / APScheduler (#128 — nightly maintenance, reflection) ──────
BANTZ_JOB_SCHEDULER_ENABLED=true
BANTZ_MAINTENANCE_HOUR=3
BANTZ_REFLECTION_HOUR=23
BANTZ_BRIEFING_PREP_HOUR=6
BANTZ_OVERNIGHT_POLL_HOURS=0,2,4,6

# ── Overnight Poll / Urgent Keywords (#132) ───────────────────────────────────
# Comma-separated keywords that mark an email as urgent (case-insensitive).
BANTZ_URGENT_KEYWORDS=urgent,acil,deadline,final,emergency,important

# ── Telegram Bot (optional — for notifications + remote control) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_PROXY=
TELEGRAM_LLM_MODE=true

# ── Background Observer (#124 — proactive error detection) ────────────────────
BANTZ_OBSERVER_ENABLED=false
BANTZ_OBSERVER_SEVERITY_THRESHOLD=warning
BANTZ_OBSERVER_BATCH_SECONDS=5
BANTZ_OBSERVER_DEDUP_WINDOW=60
BANTZ_OBSERVER_ANALYSIS_MODEL=qwen2.5:0.5b
BANTZ_OBSERVER_ENABLE_LLM=true

# ── RL Engine (#125 — adaptive routine learning) ─────────────────────────────
BANTZ_RL_ENABLED=false
BANTZ_RL_LEARNING_RATE=0.3
BANTZ_RL_DISCOUNT_FACTOR=0.9
BANTZ_RL_EXPLORATION_RATE=0.15
BANTZ_RL_EXPLORATION_MIN=0.02
BANTZ_RL_CONFIDENCE_THRESHOLD=0.7
BANTZ_RL_SUGGESTION_INTERVAL=1800

# ── Bonding Meter (#172 — progressive formality reduction) ───────────────
BANTZ_BONDING_ENABLED=true
BANTZ_BONDING_SIGMOID_RATE=0.04
BANTZ_BONDING_SIGMOID_MIDPOINT=25

# ── Proactive Interventions (#126 — toast notifications) ─────────────────────
BANTZ_INTERVENTION_RATE_LIMIT=3
BANTZ_INTERVENTION_TOAST_TTL=20
BANTZ_INTERVENTION_QUIET_MODE=false
BANTZ_INTERVENTION_FOCUS_MODE=false

# ── App Detector (#127 — active window & workspace context) ──────────────
BANTZ_APP_DETECTOR_ENABLED=false
BANTZ_APP_DETECTOR_CACHE_TTL=5
BANTZ_APP_DETECTOR_POLLING_INTERVAL=5
BANTZ_APP_DETECTOR_AUTO_FOCUS=true

# ── Desktop Notifications (#153 — notify-send for interventions) ──────────
BANTZ_DESKTOP_NOTIFICATIONS=true
BANTZ_NOTIFICATION_ICON=
BANTZ_NOTIFICATION_SOUND=false

# ══════════════════════════════════════════════════════════════════════════
# VOICE PIPELINE (#277 — Master Switch)
# ══════════════════════════════════════════════════════════════════════════
# Setting BANTZ_VOICE_ENABLED=true turns on TTS, Wake Word, STT, Ghost Loop,
# Audio Ducking, and Ambient in one shot.  Individual flags below still
# override if you want fine-grained control.
#
# ⚠️  Linux prerequisite (Ubuntu/Mint/Debian):
#     sudo apt install portaudio19-dev
#   Without this, PyAudio (and therefore wake word + STT) will fail to install.
#
BANTZ_VOICE_ENABLED=false

# ── TTS / Audio Briefing (#131 — Piper text-to-speech) ───────────────────
BANTZ_TTS_ENABLED=false
# Sesi Danny'e zorla (eski lessac-medium yerine):
BANTZ_TTS_MODEL=en_US-danny-low
BANTZ_TTS_MODEL_PATH=
BANTZ_TTS_SPEAKER=0
BANTZ_TTS_RATE=1.0
BANTZ_TTS_AUTO_BRIEFING=true
# Her LLM cevabında konuşmasını açar:
BANTZ_TTS_SPEAK_ALL_RESPONSES=false
# Karanlık mekanik efekt (SoX pitch + reverb + overdrive):
BANTZ_TTS_ANIMATRONIC_FILTER=false
# Ses seviyesi artırımı — SoX gain (dB). 0 = kapalı, 12 = varsayılan boost:
BANTZ_TTS_GAIN=12.0

# ── Audio Ducking (#171 — lower other apps while TTS speaks) ────────────
# Requires pactl (PulseAudio/PipeWire).  Duck percentage = target volume
# for other apps (30 = 30%).  Bantz's own aplay is excluded via PULSE_PROP.
BANTZ_AUDIO_DUCK_ENABLED=false
BANTZ_AUDIO_DUCK_PCT=30

# ── Wake Word Detection (#165 — "Hey Bantz" via Porcupine) ──────────────
# Get a free access key at https://console.picovoice.ai/
BANTZ_WAKE_WORD_ENABLED=false
BANTZ_PICOVOICE_ACCESS_KEY=
BANTZ_WAKE_WORD_SENSITIVITY=0.5

# ── Ghost Loop / STT (#36 — hands-free voice input) ─────────────────
# Requires: pip install faster-whisper webrtcvad pyaudio
# Also requires wake word to be enabled (BANTZ_WAKE_WORD_ENABLED=true)
# Tip: BANTZ_VOICE_ENABLED=true sets all of these automatically.
# ⚠️  First run downloads the Whisper model from HuggingFace (~39 MB for tiny).
#     The TUI will show "Downloading Whisper model…" — this is normal.
BANTZ_GHOST_LOOP_ENABLED=true
BANTZ_STT_ENABLED=true
BANTZ_STT_MODEL=tiny
BANTZ_STT_LANGUAGE=en
BANTZ_STT_DEVICE=cpu
BANTZ_VAD_SILENCE_MS=800
BANTZ_VAD_AGGRESSIVENESS=2

# ── Ambient Sound Analysis (#166 — passive env classification) ───────────
# Piggybacks on wake word mic — requires BANTZ_WAKE_WORD_ENABLED=true
BANTZ_AMBIENT_ENABLED=false
BANTZ_AMBIENT_INTERVAL=600
BANTZ_AMBIENT_WINDOW=3.0

# ── Proactive Engagement (#167 — idle conversation initiation) ───────────
# Starts conservatively: 1 message/day, scales to 3 as RL earns rewards
BANTZ_PROACTIVE_ENABLED=false
BANTZ_PROACTIVE_INTERVAL_HOURS=3.0
BANTZ_PROACTIVE_JITTER_MINUTES=30
BANTZ_PROACTIVE_MAX_DAILY=1
BANTZ_PROACTIVE_AWAY_TIMEOUT=1800

# ── Health & Break Interventions (#168 — proactive health monitoring) ────
# 5-rule engine: late night load, marathon session, eye strain, thermal, music
BANTZ_HEALTH_ENABLED=false
BANTZ_HEALTH_CHECK_INTERVAL=300
BANTZ_HEALTH_LATE_HOUR=2
BANTZ_HEALTH_SESSION_MAX_HOURS=4.0
BANTZ_HEALTH_THERMAL_CPU=85.0
BANTZ_HEALTH_THERMAL_GPU=80.0
BANTZ_HEALTH_EYE_STRAIN_HOURS=2.0

# ── Dynamic Persona (#169 — 1920s butler character adaptation) ───────────
# Dynamically adjusts tone based on telemetry, time, activity, RL reward
BANTZ_PERSONA_ENABLED=true

# ── Deep Memory / Spontaneous Recall (#170) ──────────────────────────────
# Probabilistically surfaces relevant past memories during casual chat
BANTZ_DEEP_MEMORY_ENABLED=true
BANTZ_DEEP_MEMORY_THRESHOLD=0.72
BANTZ_DEEP_MEMORY_MAX_RESULTS=3
