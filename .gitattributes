# loop_eval corpus data is generated by eval/loop_eval/variants.py, which
# writes LF. Pin these files to LF on every platform so the byte-exact
# regeneration check (tests/eval/test_corpus.py) is stable — without this,
# core.autocrlf=true on a Windows checkout rewrites them to CRLF and the
# generated-vs-committed comparison fails spuriously.
eval/loop_eval/tasks/*.jsonl text eol=lf
